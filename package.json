{
  "name": "titanos-test-automation",
  "version": "1.0.0",
  "private": true,
  "description": "TitanOS automated test suite",
  "workspaces": ["ui-tests", "api-tests"],
  "devDependencies": {
    "@typescript-eslint/parser": "^8.x",
    "eslint": "^9.x",
    "eslint-plugin-playwright": "^2.x",
    "husky": "^9.x",
    "lint-staged": "^15.x",
    "prettier": "^3.x"
  },
  "scripts": {
    "prepare": "husky || true",
    "test": "npm run test:api && npm run test:ui",
