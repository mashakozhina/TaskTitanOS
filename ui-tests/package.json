{
  "name": "ui-tests",
  "version": "1.0.0",
  "private": true,
  "description": "TitanOS UI test suite using Playwright",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
